#!/usr/bin/env bash
# Runs Nginx as the nginx user and listens on port 8080.

if ! id nginx >/dev/null 2>&1; then
    useradd -r -s /usr/sbin/nologin nginx
fi

pkill nginx || true
sleep 1

cat > /tmp/nginx.conf <<'EOF'
pid /tmp/nginx.pid;
error_log /tmp/nginx-error.log notice;

events {
    worker_connections 128;
}

http {
    access_log /tmp/nginx-access.log;

    server {
        listen 8080;
        server_name _;

        location / {
            return 200 "OK\n";
        }
    }
}
EOF

rm -f /tmp/nginx.pid /tmp/nginx-error.log /tmp/nginx-access.log
touch /tmp/nginx-error.log /tmp/nginx-access.log
chown nginx:nginx /tmp/nginx-error.log /tmp/nginx-access.log

su -s /bin/sh nginx -c "nginx -t -c /tmp/nginx.conf && nginx -c /tmp/nginx.conf"
